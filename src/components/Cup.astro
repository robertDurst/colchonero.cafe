---
// Rojiblanco cup glyph — scaled by drink size. `id` must be unique per page
// so the clipPath doesn't collide between cups.
interface Props {
  px: number;
  id: string;
}
const { px, id } = Astro.props;
const height = Math.round((px * 52) / 48);
---
<svg class="cup" width={px} height={height} viewBox="-2 -2 48 52" aria-hidden="true">
  <clipPath id={id}><path d="M6,12 L34,12 L30,40 Q29,44 25,44 L15,44 Q11,44 10,40 Z"/></clipPath>
  <g clip-path={`url(#${id})`}>
    <rect x="5" y="10" width="30" height="36" fill="#fff"/>
    <rect x="6" y="10" width="5" height="36" fill="#CE3524"/>
    <rect x="16" y="10" width="5" height="36" fill="#CE3524"/>
    <rect x="26" y="10" width="5" height="36" fill="#CE3524"/>
  </g>
  <path d="M6,12 L34,12 L30,40 Q29,44 25,44 L15,44 Q11,44 10,40 Z" fill="none" stroke="#0B1B3F" stroke-width="2.4" stroke-linejoin="round"/>
  <ellipse cx="20" cy="12" rx="14" ry="3" fill="#3A2417" stroke="#0B1B3F" stroke-width="2.4"/>
  <path d="M34,16 q8,1 7,9 q-1,7 -8,5" fill="none" stroke="#0B1B3F" stroke-width="2.6"/>
</svg>
