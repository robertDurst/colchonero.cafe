---
// The schedule is fetched live from the libero API in the browser (see the
// client script below and src/lib/events.ts); nothing is baked at build time.
import Layout from "@/layouts/Layout.astro";
import Tabs from "@/components/Tabs.astro";
import Footer from "@/components/Footer.astro";
---
<Layout
  title="Colchonero Café · Calendario"
  description="Calendario rojiblanco: partidos y eventos del Atleti."
  bodyClass="carta"
>
  <header class="carta-head">
    <a href="/" transition:persist="brand"><img class="brand" src="/logo.svg" alt="Colchonero Café — inicio" /></a>
    <h1>Calendario</h1>
    <p class="sub">Partidos y eventos rojiblancos, servidos por fecha.</p>
    <Tabs active="calendario" />
  </header>

  <main class="cal" data-state="loading">
    <ul class="legend" aria-label="Tipos de evento"></ul>

    <p class="status loading">Cargando calendario…</p>
    <p class="status error">
      No se pudo cargar el calendario.
      <button type="button" class="retry">Reintentar</button>
    </p>
    <p class="status empty">Sin eventos programados todavía.</p>

    <div class="cal-nav">
      <button class="navbtn prev" type="button" aria-label="Mes anterior">←</button>
      <h2 class="month-label"></h2>
      <button class="navbtn next" type="button" aria-label="Mes siguiente">→</button>
    </div>
    <div class="months"></div>
  </main>

  <script>
    import {
      buildMonths,
      typeKey,
      fmtEventDate,
      WEEKDAYS,
      type CalEvent,
      type DayCell,
      type MonthGrid,
    } from "../lib/calendar";
    import { fetchEvents } from "../lib/events";

    // Legend colour key, in display order.
    const KNOWN = [
      { key: "liga", label: "Liga" },
      { key: "champions", label: "Champions" },
      { key: "mundial", label: "Mundial" },
      { key: "copa", label: "Copa" },
      { key: "amistoso", label: "Amistoso" },
      { key: "otro", label: "Otro" },
    ];

    type Attrs = Record<string, string | number | boolean | undefined>;

    // Tiny DOM builder. `text` sets textContent; boolean `true` sets a bare attr.
    function el(tag: string, attrs: Attrs = {}, children: (Node | string)[] = []): HTMLElement {
      const node = document.createElement(tag);
      for (const [k, v] of Object.entries(attrs)) {
        if (v === undefined || v === false) continue;
        if (k === "text") node.textContent = String(v);
        else if (k === "class") node.className = String(v);
        else if (v === true) node.setAttribute(k, "");
        else node.setAttribute(k, String(v));
      }
      for (const c of children) node.append(c);
      return node;
    }

    const pad2 = (n: number) => String(n).padStart(2, "0");

    // The reader's local "today", so the highlight is correct wherever they are.
    function todayISO(): string {
      const d = new Date();
      return `${d.getFullYear()}-${pad2(d.getMonth() + 1)}-${pad2(d.getDate())}`;
    }

    function renderCell(cell: DayCell, today: string): HTMLElement {
      const has = cell.events.length > 0;
      const cls = ["cell"];
      if (cell.day === null) cls.push("empty");
      if (has) cls.push("has");
      if (cell.iso && cell.iso === today) cls.push("today");

      const div = el("div", {
        class: cls.join(" "),
        "data-date": has ? cell.iso : undefined,
        tabindex: has ? 0 : undefined,
        title: has ? "Ver detalle" : undefined,
      });
      if (cell.day !== null) {
        div.append(el("span", { class: "n", text: cell.day }));
        if (has) {
          const dots = el("span", { class: "dots" });
          for (const ev of cell.events) {
            dots.append(el("span", { class: `dot ${typeKey(ev.type)}`, title: ev.title || ev.type }));
          }
          div.append(dots);
        }
      }
      return div;
    }

    function renderMonth(m: MonthGrid, today: string): HTMLElement {
      const section = el("section", { class: "month", "data-label": m.label });

      const grid = el("div", { class: "grid", "aria-label": m.label });
      const weekdays = el("div", { class: "weekdays" });
      for (const d of WEEKDAYS) weekdays.append(el("span", { text: d }));
      grid.append(weekdays);

      const days = el("div", { class: "days" });
      for (const cell of m.weeks.flat()) days.append(renderCell(cell, today));
      grid.append(days);
      section.append(grid);

      if (m.events.length === 0) {
        section.append(el("p", { class: "noev", text: "Sin eventos previstos este mes." }));
        return section;
      }

      const agenda = el("ul", { class: "agenda" });
      for (const ev of m.events) {
        const li = el("li", { class: "ev", "data-date": ev.date });
        li.append(el("span", { class: `rail ${typeKey(ev.type)}`, "aria-hidden": "true" }));

        const when = el("span", { class: "when" });
        when.append(el("span", { class: "d", text: fmtEventDate(ev.date) }));
        if (ev.time) when.append(el("span", { class: "t", text: ev.time }));
        li.append(when);

        const what = el("span", { class: "what" });
        what.append(el("span", { class: "title", text: ev.title || ev.type || "Evento" }));
        if (ev.location || ev.type) {
          const sub = `${ev.location}${ev.location && ev.type ? " · " : ""}${ev.type}`;
          what.append(el("span", { class: "sub2", text: sub }));
        }
        li.append(what);
        agenda.append(li);
      }
      section.append(agenda);
      return section;
    }

    // Pick the month containing today, else the next upcoming, else the last.
    function pickStart(months: MonthGrid[], today: string): number {
      const key = (m: MonthGrid) => `${m.year}-${pad2(m.month)}`;
      const tm = today.slice(0, 7);
      let i = months.findIndex((m) => key(m) === tm);
      if (i === -1) i = months.findIndex((m) => key(m) > tm);
      if (i === -1) i = months.length - 1;
      return i;
    }

    function renderLegend(legend: HTMLElement, events: CalEvent[]) {
      const present = new Set(events.map((e) => typeKey(e.type)));
      legend.replaceChildren(
        ...KNOWN.filter((k) => present.has(k.key)).map((l) =>
          el("li", {}, [el("span", { class: `dot ${l.key}`, "aria-hidden": "true" }), l.label]),
        ),
      );
    }

    // Show only the chosen day's detail in a month; default to today if it has
    // events, otherwise the month's first event day.
    function selectDate(section: HTMLElement, date: string) {
      const agenda = section.querySelector<HTMLElement>(".agenda");
      if (!agenda) return;
      agenda.classList.add("filtered");
      section.querySelectorAll<HTMLElement>(".ev").forEach((ev) =>
        ev.classList.toggle("sel", ev.dataset.date === date),
      );
      section.querySelectorAll<HTMLElement>(".cell").forEach((cell) =>
        cell.classList.toggle("selected", !!date && cell.dataset.date === date),
      );
    }
    function defaultDate(section: HTMLElement, today: string): string {
      const dates = Array.from(section.querySelectorAll<HTMLElement>(".ev"))
        .map((ev) => ev.dataset.date ?? "")
        .sort();
      return dates.includes(today) ? today : (dates[0] ?? "");
    }

    // Wire month navigation (prev/next) and per-day selection onto fresh DOM.
    function wire(main: HTMLElement, sections: HTMLElement[], today: string, start: number) {
      const label = main.querySelector<HTMLElement>(".month-label");
      const prev = main.querySelector<HTMLButtonElement>(".navbtn.prev");
      const next = main.querySelector<HTMLButtonElement>(".navbtn.next");

      if (label && prev && next) {
        let i = start;
        const show = (n: number) => {
          i = Math.max(0, Math.min(sections.length - 1, n));
          sections.forEach((s, k) => (s.hidden = k !== i));
          label.textContent = sections[i].dataset.label ?? "";
          prev.disabled = i === 0;
          next.disabled = i === sections.length - 1;
        };
        prev.addEventListener("click", () => show(i - 1));
        next.addEventListener("click", () => show(i + 1));
        show(i);
      }

      sections.forEach((section) => {
        selectDate(section, defaultDate(section, today));
        section.querySelectorAll<HTMLElement>(".cell.has").forEach((cell) => {
          const pick = () => selectDate(section, cell.dataset.date ?? "");
          cell.addEventListener("click", pick);
          cell.addEventListener("keydown", (e) => {
            if (e.key === "Enter" || e.key === " ") {
              e.preventDefault();
              pick();
            }
          });
        });
      });
    }

    let controller: AbortController | null = null;

    async function load(main: HTMLElement) {
      controller?.abort();
      controller = new AbortController();
      const monthsBox = main.querySelector<HTMLElement>(".months");
      const legend = main.querySelector<HTMLElement>(".legend");
      if (!monthsBox || !legend) return;

      main.dataset.state = "loading";
      try {
        const events = await fetchEvents(controller.signal);
        if (events.length === 0) {
          monthsBox.replaceChildren();
          legend.replaceChildren();
          main.dataset.state = "empty";
          return;
        }

        const today = todayISO();
        const months = buildMonths(events);
        const start = pickStart(months, today);

        renderLegend(legend, events);
        const sections = months.map((m) => renderMonth(m, today));
        sections.forEach((s, k) => (s.hidden = k !== start));
        monthsBox.replaceChildren(...sections);
        wire(main, sections, today, start);

        main.dataset.state = "ready";
      } catch (err) {
        if ((err as Error)?.name === "AbortError") return;
        main.dataset.state = "error";
      }
    }

    // Re-run on every view-transition navigation, not just the first load.
    function init() {
      const main = document.querySelector<HTMLElement>(".cal");
      if (!main) return;
      main.querySelector<HTMLButtonElement>(".retry")?.addEventListener("click", () => load(main));
      load(main);
    }
    document.addEventListener("astro:page-load", init);
  </script>

  <Footer />
</Layout>

<!--
  The calendar grid is built at runtime by the page script (createElement),
  so its nodes don't carry Astro's scoped-style attribute. These styles are
  therefore is:global, namespaced under .cal (which only exists on this page)
  so generic class names like .cell/.dot/.title don't leak to other pages.
-->
<style is:global>
  .cal {
    max-width: 680px;
    margin: 24px auto 8px;
    padding: 0 20px;
  }

  /* ── Load states (loading / error / empty) ── */
  .cal .status {
    display: none;
    text-align: center;
    color: var(--tinta);
    margin: 40px auto;
    max-width: 40ch;
    line-height: 1.6;
  }
  .cal .status .retry {
    margin-left: 6px;
    border: 1px solid var(--navy);
    background: transparent;
    color: var(--navy);
    border-radius: 6px;
    padding: 2px 10px;
    font: inherit;
    cursor: pointer;
  }
  .cal .status .retry:hover { background: var(--navy); color: var(--crema); }

  .cal[data-state="loading"] .status.loading,
  .cal[data-state="error"] .status.error,
  .cal[data-state="empty"] .status.empty { display: block; }

  /* Legend, month nav and grids only appear once the live fetch resolves. */
  .cal:not([data-state="ready"]) .legend,
  .cal:not([data-state="ready"]) .cal-nav,
  .cal:not([data-state="ready"]) .months { display: none; }

  /* ── Legend ── */
  .cal .legend {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 8px 18px;
    justify-content: center;
    margin: 0 0 24px;
    padding: 0;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--tinta);
  }
  .cal .legend li {
    display: flex;
    align-items: center;
    gap: 7px;
  }

  /* ── Type colour dots ── */
  .cal .dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--tinta);
    flex: 0 0 auto;
  }
  .cal .dot.liga { background: var(--rojo); }
  .cal .dot.champions { background: var(--navy); }
  .cal .dot.mundial { background: #0e8388; }
  .cal .dot.copa { background: #d4a017; }
  .cal .dot.amistoso { background: #2e7d4f; }
  .cal .dot.otro { background: #7a6a55; }

  /* ── Month navigation ── */
  .cal .cal-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    margin: 0 0 18px;
  }
  .cal .cal-nav .month-label {
    margin: 0;
    min-width: 9.5em;
    text-align: center;
    text-transform: capitalize;
    letter-spacing: 0.04em;
    font-size: 1.5rem;
    color: var(--navy);
  }
  .cal .navbtn {
    width: 40px;
    height: 40px;
    flex: 0 0 auto;
    border-radius: 50%;
    border: 2px solid var(--navy);
    background: transparent;
    color: var(--navy);
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, color 0.15s, opacity 0.15s;
  }
  .cal .navbtn:hover:not(:disabled) {
    background: var(--navy);
    color: var(--crema);
  }
  .cal .navbtn:disabled {
    opacity: 0.3;
    cursor: default;
  }

  /* ── Month ── */
  .cal .month {
    margin: 0 0 40px;
  }

  /* ── Grid ── */
  .cal .grid {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(11, 27, 63, 0.1);
  }
  .cal .weekdays,
  .cal .days {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
  }
  /* Fixed, equal row heights — keeps padding-cell rows the same as day rows. */
  .cal .days {
    grid-auto-rows: 46px;
    align-content: start;
  }
  .cal .weekdays {
    background: var(--navy);
  }
  .cal .weekdays span {
    text-align: center;
    padding: 8px 0;
    color: var(--crema);
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.05em;
  }
  .cal .cell {
    position: relative;
    padding: 5px 6px;
    border-top: 1px solid rgba(11, 27, 63, 0.08);
    border-left: 1px solid rgba(11, 27, 63, 0.08);
  }
  .cal .cell:nth-child(7n + 1) { border-left: none; }
  /* Padding cells (days outside this month) stay blank so they recede. */
  .cal .cell.empty {
    background: transparent;
    border-color: transparent;
  }
  .cal .cell .n {
    font-size: 0.82rem;
    font-variant-numeric: tabular-nums;
    color: var(--tinta);
  }
  .cal .cell.has {
    cursor: pointer;
  }
  .cal .cell.has:hover {
    background: rgba(206, 53, 36, 0.06);
  }
  .cal .cell.has:focus-visible {
    outline: 2px solid var(--rojo);
    outline-offset: -2px;
  }
  .cal .cell.has .n {
    font-weight: 700;
    color: var(--navy);
  }
  .cal .cell.selected {
    background: rgba(11, 27, 63, 0.1);
    box-shadow: inset 0 0 0 2px var(--navy);
  }
  .cal .cell.today {
    background: rgba(206, 53, 36, 0.08);
  }
  .cal .cell.today .n {
    background: var(--rojo);
    color: #fff;
    border-radius: 50%;
    width: 1.5em;
    height: 1.5em;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .cal .cell .dots {
    position: absolute;
    left: 6px;
    bottom: 6px;
    display: flex;
    flex-wrap: wrap;
    gap: 3px;
  }

  /* ── Selected-day detail under the grid ── */
  .cal .agenda {
    list-style: none;
    margin: 14px 0 0;
    padding: 0;
  }
  .cal .ev {
    display: flex;
    align-items: stretch;
    gap: 12px;
    padding: 10px 4px;
    border-bottom: 1px dashed rgba(11, 27, 63, 0.22);
  }
  .cal .ev:last-child { border-bottom: none; }

  /* Once JS is active, only the selected day's events are shown. */
  .cal .agenda.filtered .ev { display: none; }
  .cal .agenda.filtered .ev.sel { display: flex; }
  .cal .agenda.filtered .ev.sel { border-bottom: none; }

  .cal .noev {
    text-align: center;
    color: var(--tinta);
    opacity: 0.7;
    margin: 18px 0 0;
    font-size: 0.95rem;
  }
  .cal .ev .rail {
    width: 4px;
    border-radius: 4px;
    background: var(--tinta);
    flex: 0 0 auto;
  }
  .cal .ev .rail.liga { background: var(--rojo); }
  .cal .ev .rail.champions { background: var(--navy); }
  .cal .ev .rail.mundial { background: #0e8388; }
  .cal .ev .rail.copa { background: #d4a017; }
  .cal .ev .rail.amistoso { background: #2e7d4f; }
  .cal .ev .rail.otro { background: #7a6a55; }
  .cal .ev .when {
    flex: 0 0 6.5em;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .cal .ev .when .d {
    font-weight: 700;
    font-size: 0.9rem;
    text-transform: capitalize;
    color: var(--navy);
  }
  .cal .ev .when .t {
    font-size: 0.78rem;
    color: var(--tinta);
    font-variant-numeric: tabular-nums;
  }
  .cal .ev .what {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: 0;
  }
  .cal .ev .what .title {
    font-weight: 700;
    font-size: 1.02rem;
    line-height: 1.2;
  }
  .cal .ev .what .sub2 {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    opacity: 0.65;
  }

  @media (max-width: 560px) {
    .cal .days { grid-auto-rows: 40px; }
    .cal .cell .n { font-size: 0.78rem; }
  }
</style>
