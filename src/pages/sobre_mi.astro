---
import Layout from "@/layouts/Layout.astro";
import Tabs from "@/components/Tabs.astro";
import Footer from "@/components/Footer.astro";
---
<Layout
  title="Sobre mí · Colchonero Café"
  description="El colchonero detrás de la barra."
  bodyClass="carta"
>
  <header class="carta-head">
    <a href="/" transition:persist="brand"><img class="brand" src="/logo.svg" alt="Colchonero Café — inicio" /></a>
    <h1>Sobre mí</h1>
    <Tabs active="sobre_mi" />
  </header>

  <main class="perfil">
    <div class="avatar-wrap">
      <img class="avatar" src="/images/yo.jpg" alt="Foto del autor" />
    </div>

    <h2 class="nombre">El Tostador</h2>
    <p class="lema">Rojiblanco de corazón, cafetero de vocación.</p>

    <div class="divider"></div>

    <p class="bio">
      Llevo toda la vida siguiendo deportes y disfrutar cafés de muchos sabores
      diferentes. Y finalmente llegué al "beautiful game" con un espresso en
      mano (<em>en esta foto, estaba en el tercer piso de un Corte Inglés cerca
      de la Puerta del Sol</em>). Creé este blog para compartir mis experiencias
      aprendiendo español y fútbol y, con suerte, ver a nuestro Atleti ganar la
      liga una vez más. ¡Aúpa Atleti!
    </p>
  </main>

  <Footer />
</Layout>

<style>
  .perfil {
    max-width: 560px;
    margin: 40px auto 80px;
    padding: 0 22px;
    text-align: center;
  }

  /* ── Avatar ── */
  .avatar-wrap {
    display: inline-block;
    padding: 5px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--rojo), var(--navy));
    box-shadow: 0 8px 28px rgba(11, 27, 63, 0.22);
    margin-bottom: 20px;
  }
  .avatar {
    display: block;
    width: 160px;
    height: 160px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid var(--crema);
  }

  /* ── Name & tagline ── */
  .nombre {
    margin: 0 0 0.15em;
    font-size: clamp(1.6rem, 5vw, 2.2rem);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--navy);
  }
  .lema {
    margin: 0 0 1.2em;
    font-size: 1rem;
    color: var(--rojo);
    font-weight: 700;
    letter-spacing: 0.03em;
  }

  /* ── Divider (same stripes as the home page, smaller) ── */
  .divider {
    width: min(180px, 60vw);
    height: 8px;
    margin: 0 auto 1.6em;
    border-radius: 5px;
    border: 2px solid var(--navy);
    background: repeating-linear-gradient(
      90deg,
      var(--rojo) 0 12px,
      #fff 12px 24px
    );
  }

  /* ── Bio ── */
  .bio {
    font-size: 1.08rem;
    line-height: 1.75;
    color: var(--tinta);
    margin: 0 0 1em;
    text-align: left;
  }
  .bio em {
    font-style: italic;
    color: var(--rojo);
  }
</style>
