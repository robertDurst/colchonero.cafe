---
import Layout from "@/layouts/Layout.astro";
import Footer from "@/components/Footer.astro";
---
<Layout
  title="Colchonero Café · Atleti, café y fanáticos"
  description="Colchonero Café — rincón rojiblanco para fanáticos del Atlético de Madrid. Café, fútbol y orgullo colchonero."
  bodyClass="home"
>
  <img class="logo" src="/logo.svg" alt="Escudo de Colchonero Café: taza de café con franjas rojiblancas" />
  <h1>Colchonero <span class="rojo">Café</span></h1>
  <p class="tag">Café cargado y orgullo rojiblanco. El rincón de los fanáticos del Atleti.</p>
  <div class="stripes" aria-hidden="true"></div>
  <a class="cta" href="/carta">Entra a La Carta →</a>
  <nav class="home-menu" aria-label="Más secciones">
    <a class="home-row" href="/calendario">
      <svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
        <rect x="3" y="4.5" width="18" height="16.5" rx="2.5" />
        <path d="M8 2.5v4M16 2.5v4M3 9.5h18" />
        <circle cx="8" cy="14" r="0.6" fill="currentColor" stroke="none" />
        <circle cx="12" cy="14" r="0.6" fill="currentColor" stroke="none" />
        <circle cx="16" cy="14" r="0.6" fill="currentColor" stroke="none" />
        <circle cx="8" cy="17.6" r="0.6" fill="currentColor" stroke="none" />
        <circle cx="12" cy="17.6" r="0.6" fill="currentColor" stroke="none" />
      </svg>
      <span class="label">Calendario</span>
      <span class="arrow" aria-hidden="true">→</span>
    </a>
    <a class="home-row" href="/recursos">
      <svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
        <path d="M9 13a4 4 0 0 0 5.66.4l3-3a4 4 0 0 0-5.66-5.66l-1.5 1.5" />
        <path d="M15 11a4 4 0 0 0-5.66-.4l-3 3a4 4 0 0 0 5.66 5.66l1.5-1.5" />
      </svg>
      <span class="label">Recursos</span>
      <span class="arrow" aria-hidden="true">→</span>
    </a>
    <a class="home-row" href="/sobre_mi">
      <svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
        <path d="M8.8 2.6c-.6 1 .6 1.6 0 2.6" stroke-width="1.5" />
        <path d="M12 2.6c-.6 1 .6 1.6 0 2.6" stroke-width="1.5" />
        <path d="M15.2 2.6c-.6 1 .6 1.6 0 2.6" stroke-width="1.5" />
        <path d="M4 7.6h13l-1.2 8.2a2 2 0 0 1-2 1.7H7.2a2 2 0 0 1-2-1.7z" />
        <path d="M17 9.6h1.3a2.4 2.4 0 0 1 0 4.8H16.4" />
        <path d="M4.5 20.6q6 1.9 12 0" stroke-width="1.7" />
      </svg>
      <span class="label">Sobre mí</span>
      <span class="arrow" aria-hidden="true">→</span>
    </a>
  </nav>
  <Footer />
</Layout>
